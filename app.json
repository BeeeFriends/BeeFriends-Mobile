{
  "expo": {
    "name": "BeeFriends-FE",
    "slug": "BeeFriends-FE",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/beefriends_logo.png",
    "scheme": "beefriendsfe",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/beefriends_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFDD2D",
        "foregroundImage": "./assets/images/beefriends_logo.png",
        "monochromeImage": "./assets/images/beefriends_logo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/beefriends_logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
